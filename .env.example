# HubWorkz Saúde — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no Git.
#
# No Replit: configure via painel Secrets (cadeado na barra lateral).
# Em servidor próprio: exporte as vars antes de iniciar os processos.

# ── Supabase ────────────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Project Settings → API

# URL do projeto Supabase (usada tanto no frontend quanto no backend)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave anônima — segura para uso no frontend (RLS aplica restrições)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de service role — SOMENTE no servidor, NUNCA no frontend
# Bypassa RLS: use apenas em rotas Express protegidas
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic — Di IA ────────────────────────────────────────────────────────
# Encontre em: console.anthropic.com → API Keys
# Usada pelo servidor Express para claude-sonnet-4-5 (assistente Di IA)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Sessão / Segurança ───────────────────────────────────────────────────────
# String aleatória longa para assinar sessões (gere com: openssl rand -base64 32)
SESSION_SECRET=troque-por-string-aleatoria-segura-min-32-chars

# ── Servidor Express (API) ───────────────────────────────────────────────────
# No Replit o artifact.toml injeta PORT=8080 automaticamente.
# Em servidor próprio, defina conforme necessidade.
PORT=8080
NODE_ENV=production

# ── NÃO CONFIGURAR — Gerenciado automaticamente ─────────────────────────────
# VITE_API_URL  → não necessário: o proxy reverso do Replit roteia /api
# Evolution API → desativado neste projeto (ver replit.md)
